# ==========================================
# 🛑 SECRETS: DO NOT COMMIT ACTUAL VALUES 🛑
# Copy this file to .env and fill in 
# your real pricing data.
# ==========================================

# -- MATERIAL COSTS (EUR per 1kg) --
COST_PLA=14.00
COST_ABS=12.00
COST_PETG=11.50

# -- MATERIAL DENSITIES (g/cm3) --
DENSITY_PLA=1.24
DENSITY_ABS=1.04
DENSITY_PETG=1.27

# -- PREPARATION / HEAT-UP TIME (Minutes) --
PREP_PLA=7
PREP_PETG=7
# ABS needs a chamber soak
PREP_ABS=37

# -- MAX VOLUMETRIC SPEED (mm3/s) --
# PLA can usually handle 12-15 mm3/s
VOLUMETRIC_SPEED_PLA=12
# ABS is similar to PLA but often capped slightly lower for quality
VOLUMETRIC_SPEED_ABS=7
# PETG is stickier and usually needs to go slower
VOLUMETRIC_SPEED_PETG=8

# -- PRINTER BUILD VOLUME (mm) --
# Dimensions for Bambu Lab P1S (256 x 256 x 256)
NEXT_PUBLIC_MAX_X=256
NEXT_PUBLIC_MAX_Y=256
NEXT_PUBLIC_MAX_Z=256

# -- MACHINE & ENERGY COSTS --
# Hourly cost to run the printer (electricity + wear/tear)
MACHINE_HOURLY_RATE=2.50

# -- LABOR COSTS --
# Your hourly rate for manual work (slicing, post-processing)
LABOR_HOURLY_RATE=25.00
# Fixed amount of labor time per print (e.g., 0.125 = 7,5 minutes)
DEFAULT_LABOR_HOURS=0.125

# -- BUFFERS & PROFIT --
# Failure buffer: 0.10 adds 10% to the base cost
FAILURE_BUFFER_PCT=0.10
# Profit Margin: 1.5 adds a 50% markup to everything
PROFIT_MARGIN_MULTIPLIER=1.50

# VAT Percentage (e.g., 24 for 24%)
# If left blank or removed, VAT will not be applied.
VAT_PERCENTAGE=25.5